# === 推送渠道（至少配一个）===
# Server酱: https://sct.ftqq.com/ 注册获取
SERVERCHAN_SENDKEY=

# PushPlus: https://www.pushplus.plus/ 注册获取
PUSHPLUS_TOKEN=

# 企业微信群机器人 webhook URL
WECOM_BOT_WEBHOOK=

# Qmsg酱: https://qmsg.zendee.cn/
QMSG_KEY=
QMSG_QQ=

# === Gmail 监控 ===
# 需要 credentials.json（Google Cloud OAuth），参考 README 配置
# 代理设置（访问 googleapis.com 需要，留空则不使用代理）
HTTP_PROXY=http://127.0.0.1:7897
HTTPS_PROXY=http://127.0.0.1:7897
